# ============================================
# B2B PROPOSAL GENERATOR - ENVIRONMENT CONFIG
# Using: Llama 3.3 70B via OpenRouter (FREE)
# ============================================

# OpenRouter (REQUIRED) - Get from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Tavily Web Search (REQUIRED, FREE tier) - Get from: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# LangSmith Tracing (OPTIONAL) - Get from: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=b2b-proposal-generator

# ─── Model Configuration ───
LLM_PROVIDER=openrouter
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_TEMPERATURE=0.3

# Embeddings: HuggingFace all-MiniLM-L6-v2 (FREE, runs locally)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Storage ───
CHROMA_PERSIST_DIR=./chroma_db
SQLITE_CHECKPOINT_PATH=./checkpoints.db
